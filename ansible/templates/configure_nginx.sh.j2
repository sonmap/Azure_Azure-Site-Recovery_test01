#!/usr/bin/env bash
set -euo pipefail

export DEBIAN_FRONTEND=noninteractive

apt-get update -y
apt-get install -y nginx curl jq

REGION="unknown"
VM_NAME="unknown"
PRIVATE_IP="unknown"

META_BASE="http://169.254.169.254/metadata/instance"
META_HEADER="Metadata:true"

REGION=$(curl -fsS -H "${META_HEADER}" "${META_BASE}/compute/location?api-version=2021-02-01&format=text" || echo "unknown")
VM_NAME=$(curl -fsS -H "${META_HEADER}" "${META_BASE}/compute/name?api-version=2021-02-01&format=text" || hostname)
PRIVATE_IP=$(hostname -I | awk '{print $1}')

mkdir -p /var/www/html

cat >/var/www/html/index.html <<HTML
<!doctype html>
<html>
<head>
  <meta charset="utf-8">
  <title>ASR DR Test</title>
  <style>
    body { font-family: Arial, sans-serif; margin: 40px; }
    .box { border: 1px solid #ddd; padding: 24px; border-radius: 8px; }
    .ok { color: #107c10; font-weight: bold; }
  </style>
</head>
<body>
  <div class="box">
    <h1>Azure Site Recovery DR Test</h1>
    <p class="ok">nginx configured by Ansible</p>
    <p><b>Role:</b> {{ role_label }}</p>
    <p><b>Azure region:</b> ${REGION}</p>
    <p><b>VM name:</b> ${VM_NAME}</p>
    <p><b>Private IP:</b> ${PRIVATE_IP}</p>
    <p><b>Updated:</b> $(date -Is)</p>
  </div>
</body>
</html>
HTML

echo "ok $(date -Is) ${REGION} ${VM_NAME}" >/var/www/html/health

systemctl enable nginx
systemctl restart nginx
systemctl status nginx --no-pager
